# ════════════════════════════════════════════════════════════════════
# Stock-Price-Sales-Forecasting-Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────
APP_NAME=Stock-Price-Sales-Forecasting-Engine
VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────────────
# Generate a secure key: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-a-256-bit-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (PostgreSQL / TimescaleDB) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://forecasting_user:forecasting_pass@localhost:5432/forecasting_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# ── Redis Cache ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# ── External API Keys ────────────────────────────────────────────────
# Yahoo Finance requires no key (primary data source)
# Get free keys from the providers below for enhanced features:

# Alpha Vantage — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub — https://finnhub.io/register (real-time data + news)
FINNHUB_API_KEY=

# OpenAI — https://platform.openai.com/api-keys (required for AI Copilot)
OPENAI_API_KEY=

# NewsAPI — https://newsapi.org/register
NEWS_API_KEY=

# FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ── MLflow Tracking ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_STOCK=stock_forecasting
MLFLOW_EXPERIMENT_SALES=sales_forecasting

# ── Model Configuration ──────────────────────────────────────────────
MODEL_CACHE_DIR=./ml/model_registry
LOOKBACK_WINDOW=60
BATCH_SIZE=64
MAX_EPOCHS=100

# ── Monitoring ───────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ── Rate Limiting ────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ── Frontend (Streamlit) ─────────────────────────────────────────────
BACKEND_URL=http://localhost:8000/api/v1
